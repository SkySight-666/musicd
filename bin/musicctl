#!/bin/sh

SOCKET_PATH="${MUSICD_SOCKET:-/tmp/musicd.sock}"

if [ $# -lt 1 ]; then
  echo "usage: musicctl <state|outputs|play URL|enqueue URL|pause|resume|stop|next|set-output NAME|quit>" >&2
  exit 1
fi

command_name="$1"
shift

case "$command_name" in
  state)
    payload="GET_STATE"
    ;;
  outputs)
    payload="LIST_OUTPUTS"
    ;;
  play)
    if [ -z "${1:-}" ]; then
      echo "PLAY requires URL" >&2
      exit 1
    fi
    payload="PLAY $1"
    ;;
  enqueue)
    if [ -z "${1:-}" ]; then
      echo "ENQUEUE requires URL" >&2
      exit 1
    fi
    payload="ENQUEUE $1"
    ;;
  pause)
    payload="PAUSE"
    ;;
  resume)
    payload="RESUME"
    ;;
  stop)
    payload="STOP"
    ;;
  next)
    payload="NEXT"
    ;;
  set-output)
    if [ -z "${1:-}" ]; then
      echo "SET_OUTPUT requires device name" >&2
      exit 1
    fi
    payload="SET_OUTPUT $1"
    ;;
  quit)
    payload="QUIT"
    ;;
  *)
    echo "unknown command: $command_name" >&2
    exit 1
    ;;
esac

send_with_nc() { printf '%s\n' "$payload" | nc -U "$SOCKET_PATH"; }
send_with_busybox_nc() { printf '%s\n' "$payload" | busybox nc -U "$SOCKET_PATH"; }
send_with_socat() { printf '%s\n' "$payload" | socat - "UNIX-CONNECT:$SOCKET_PATH"; }

if command -v nc >/dev/null 2>&1; then
  if send_with_nc 2>/dev/null; then
    exit 0
  fi
fi

if command -v busybox >/dev/null 2>&1; then
  if send_with_busybox_nc 2>/dev/null; then
    exit 0
  fi
fi

if command -v socat >/dev/null 2>&1; then
  if send_with_socat 2>/dev/null; then
    exit 0
  fi
fi

echo "No usable Unix socket client found. Install netcat (with -U) or socat." >&2
exit 1
