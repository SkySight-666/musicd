#!/bin/sh

SOCKET_PATH="${MUSICD_SOCKET:-/tmp/musicd.sock}"

if [ $# -lt 1 ]; then
  echo "usage: musicctl <state|outputs|play URL|enqueue URL|pause|resume|stop|next|set-output NAME|quit>" >&2
  exit 1
fi

command_name="$1"
shift

case "$command_name" in
  state)
    payload="GET_STATE"
    ;;
  outputs)
    payload="LIST_OUTPUTS"
    ;;
  play)
    payload="PLAY $1"
    ;;
  enqueue)
    payload="ENQUEUE $1"
    ;;
  pause)
    payload="PAUSE"
    ;;
  resume)
    payload="RESUME"
    ;;
  stop)
    payload="STOP"
    ;;
  next)
    payload="NEXT"
    ;;
  set-output)
    payload="SET_OUTPUT $1"
    ;;
  quit)
    payload="QUIT"
    ;;
  *)
    echo "unknown command: $command_name" >&2
    exit 1
    ;;
esac

if ! command -v nc >/dev/null 2>&1; then
  echo "nc is required" >&2
  exit 1
fi

printf '%s\n' "$payload" | nc -U "$SOCKET_PATH"
